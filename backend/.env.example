# App Environment Mode (development or production)
ENV=development

# Database Configuration
# - SQLite fallback (local): Leave empty
# - Supabase PostgreSQL: e.g. postgresql://user:password@host:port/dbname
DATABASE_URL=

# Security Configuration
# - JWT_SECRET_KEY must be a cryptographically secure hex string at least 32 characters long
# - Generate one with: openssl rand -hex 32
JWT_SECRET_KEY=<your_min_32_character_hex_key>

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS & Upload Configuration (Optional)
# - FRONTEND_URL: Base URL of hosted React client
# - CORS_ORIGINS: Comma-separated list of allowed origins
# - MAX_PDF_SIZE_MB: Maximum PDF upload size in megabytes
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
MAX_PDF_SIZE_MB=5

# Gemini API Key (Required in production mode, optional in development)
GEMINI_API_KEY=your_gemini_api_key_here

# Dev Mock Mode (Set to true to bypass Gemini API calls and save quota during local testing)
AI_MOCK_MODE=false
